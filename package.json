{
  "name": "assembly-api-mcp",
  "version": "0.1.0",
  "description": "대한민국 국회 Open API MCP 서버 — 국회의원, 의안, 일정, 회의록 등 국회 데이터 접근",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "assembly-api-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "cli": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hollobit/assembly-api-mcp.git"
  },
  "keywords": [
    "mcp",
    "korea",
    "national-assembly",
    "국회",
    "open-data"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
