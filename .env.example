# ============================================================
# 국회 API MCP 서버 (assembly-api-mcp) - 환경 변수 설정
# ============================================================
# 이 파일을 .env로 복사한 후 실제 인증키를 입력하세요:
#   cp .env.example .env
#
# .env 파일은 절대 git에 커밋하지 마세요.
# ============================================================

# ------------------------------------------------------------
# 1. 열린국회정보 (open.assembly.go.kr)
# ------------------------------------------------------------
# 발급: https://open.assembly.go.kr → 회원가입 → 마이페이지 → OPEN API → 인증키 발급
# 파라미터명: KEY (또는 authKey)
# Rate Limit: 개발계정 10,000 요청/월
# 테스트: "sample" 입력 시 최대 10건 조회 가능
ASSEMBLY_API_KEY=sample

# ------------------------------------------------------------
# 2. 공공데이터포털 (data.go.kr)
# ------------------------------------------------------------
# 발급: https://data.go.kr → 회원가입 → API 활용 신청 → 승인 → 인증키
# 파라미터명: ServiceKey
# Rate Limit: 개발계정 10,000 요청/월
# 주의: URL 인코딩된 키와 디코딩된 키 2종 발급됨 → 디코딩된 키 사용 권장
#
# 아래 API들을 개별 신청해야 합니다:
#   - 국회의원 정보 통합 API (15126133)
#   - 의안정보 통합 API (15126134)
#   - 국회일정 통합 API (15126132)
#   - 회의록 정보 API
#   - 국회입법조사처 자료 통합 API (15126137)
DATA_GO_KR_SERVICE_KEY=

# ------------------------------------------------------------
# 3. 국회도서관 (nanet.go.kr) [선택]
# ------------------------------------------------------------
# 발급: https://www.nanet.go.kr/usermadang/etc/openApiView.do
# 문의: 데이터융합분석과 02-6788-4475
NANET_API_KEY=

# ------------------------------------------------------------
# 4. 국회예산정책처 (nabo.go.kr) [선택]
# ------------------------------------------------------------
# 발급: https://www.nabo.go.kr/ko/api/apiUseInfo.do
# 인증: SNS 인증 (Naver 또는 Kakao) → 관리자 승인 → 인증키 발급
# 문의: 02-2070-3114, iamnabo@nabo.go.kr
NABO_API_KEY=

# ------------------------------------------------------------
# 5. 서버 설정
# ------------------------------------------------------------
# MCP 도구 프로필: lite (7개 도구, 기본) 또는 full (23개 도구)
# lite: AI 에이전트 최적화 — 토큰 73% 절감, Cursor 호환
# full: 기존 23개 도구 전부 노출 (파워유저/자체호스팅)
MCP_PROFILE=lite

# MCP 서버 전송 모드: stdio (로컬) 또는 http (원격)
MCP_TRANSPORT=stdio

# HTTP 모드 시 포트 (기본: 3000)
MCP_PORT=3000

# 로그 레벨: debug, info, warn, error
LOG_LEVEL=info

# ------------------------------------------------------------
# 6. 캐싱 설정
# ------------------------------------------------------------
# 캐시 활성화 (true/false)
CACHE_ENABLED=true

# 캐시 TTL (초) - 의원/위원회 등 정적 데이터
CACHE_TTL_STATIC=86400

# 캐시 TTL (초) - 일정/의안 등 동적 데이터
CACHE_TTL_DYNAMIC=3600

# ------------------------------------------------------------
# 7. API 응답 설정
# ------------------------------------------------------------
# 기본 응답 포맷: json 또는 xml
DEFAULT_RESPONSE_TYPE=json

# 기본 페이지 크기
DEFAULT_PAGE_SIZE=20

# 최대 페이지 크기
MAX_PAGE_SIZE=100
